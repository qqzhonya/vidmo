	include ../var/sidebar.pug

	.wrapper
		.wrapper-box
			.breadcrumbs
				a(href="").breadcrumbs-elem Главная 
				a(href="").breadcrumbs-elem Войти
			
			.wrapper-row
				.wrapper-heading
					span Войти
			
			.wrapper-row.wrapper-form
				form(action="").main-form
					.main-form-input-wrap
						input(type="email" name="Email" placeholder="Email" required).main-form-input.formEmail
					.main-form-input-wrap
						input(type="password" name="Password" placeholder="Пароль" minlength="4" required).main-form-input.formPassword
					.main-form-btn-wrap
						button.main-form-btn 
							span Войти
						.main-form-link-wrap
							a(href="password_page.html").main-form-link Забыли пароль?
							a(href="registration_page.html").main-form-link Зарегистрироваться
			
